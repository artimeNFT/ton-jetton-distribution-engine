{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "./",
    "types": ["node", "jest"]
  },
  "include": ["scripts/**/*.ts", "lib/**/*.ts", "build/**/*.ts", "tests/**/*.ts"]
}